{
  "name": "@cgyou/venom-init",
  "version": "2.1.1",
  "description": "Venom 하네스(.claude/, CLAUDE.md)를 임의의 프로젝트에 한 줄로 설치/업데이트하는 CLI",
  "type": "module",
  "bin": {
    "venom-init": "bin/venom-init.mjs"
  },
  "files": [
    "bin",
    "CLAUDE.md",
    ".claude",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "README.zh-TW.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "bash -c 'set -e; for f in .claude/hooks/*.sh .claude/hooks/lib/*.sh; do bash -n \"$f\"; done && python3 -c \"import json;json.load(open(\\\".claude/settings.json\\\"))\" && echo OK'"
  },
  "keywords": [
    "claude-code",
    "claude",
    "venom",
    "harness",
    "cli"
  ],
  "homepage": "https://github.com/KirSsuRyu/venom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KirSsuRyu/venom.git"
  },
  "bugs": {
    "url": "https://github.com/KirSsuRyu/venom/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
